# cascade backend — environment variable reference
#
# Copy this file to .env for local development:
#   cp backend/.env.example backend/.env
#
# .env is gitignored and must never be committed.
# Optional variables have defaults shown. Required variables are marked.

# ── Server ────────────────────────────────────────────────────────────────────

# TCP port the HTTP server listens on.
PORT=3000

# ── Logging ───────────────────────────────────────────────────────────────────

# Tracing filter — controls log verbosity.
# Examples: "info", "debug", "tower_http=debug,backend=info"
RUST_LOG=info

# ── Database (REQUIRED) ───────────────────────────────────────────────────────

# PostgreSQL connection string.  The backend will not start without this.
# For local dev, use the credentials from docker-compose.yml at the repo root:
DATABASE_URL=postgres://cascade:cascade@localhost:5432/cascade

# ── Stellar RPC ───────────────────────────────────────────────────────────────

# Soroban RPC endpoint for the target network. Defaults to testnet if unset.
# SOROBAN_RPC_URL=https://soroban-testnet.stellar.org:443

# Registry contract ID (C... strkey). REQUIRED — the sync worker needs this.
REGISTRY_CONTRACT_ID=CC4BP273CO73T6AXOMILHWXF37EJ5B766JEOKCYTET4YBHE3FX46GYNI

# How often the sync worker polls for new events (seconds). Default: 5.
# SYNC_POLL_INTERVAL_SECS=5
