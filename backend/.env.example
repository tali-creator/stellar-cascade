# cascade backend — environment variable reference
#
# Copy this file to .env for local development:
#   cp .env.example .env
#
# .env is gitignored and must never be committed.
# All variables are optional; defaults are shown below.

# ── Server ────────────────────────────────────────────────────────────────────

# TCP port the HTTP server listens on.
PORT=3000

# ── Logging ───────────────────────────────────────────────────────────────────

# Tracing filter — controls log verbosity.
# Examples: "info", "debug", "tower_http=debug,backend=info"
RUST_LOG=info

# ── Database (added in B5) ────────────────────────────────────────────────────

# PostgreSQL connection string.
# DATABASE_URL=postgres://user:password@localhost:5432/cascade

# ── Stellar RPC (added in a later issue) ──────────────────────────────────────

# Soroban RPC endpoint for the target network.
# SOROBAN_RPC_URL=https://soroban-testnet.stellar.org:443
